            <Font size="24.0" />
         </font>
      </Button>
      <Label alignment="CENTER" contentDisplay="CENTER" layoutX="511.0" layoutY="460.0" prefHeight="31.0" prefWidth="178.0" text="Choose simulation size:" textAlignment="CENTER">
