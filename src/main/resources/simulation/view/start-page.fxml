            <Font size="14.0" />
         </font>
      </Label>
      <TextField fx:id="mainTitle" alignment="CENTER" editable="false" layoutX="377.0" layoutY="196.0" prefHeight="157.0" prefWidth="493.0" text="The Simulation has you...">
         <font>
            <Font size="24.0" />
         </font>
      </TextField>
      <ChoiceBox fx:id="chooseSize" layoutX="525.0" layoutY="491.0" prefWidth="150.0" />
   </children>
</AnchorPane>
